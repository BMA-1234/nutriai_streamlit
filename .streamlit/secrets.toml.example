# Copy this file to secrets.toml for local dev, OR paste into Streamlit Cloud → App Settings → Secrets

OPENROUTER_API_KEY = "sk-or-v1-your-key-here"

# Level 1+2: Supabase (free at supabase.com)
SUPABASE_URL      = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Level 3: Stripe (stripe.com)
STRIPE_SECRET_KEY = "sk_live_..."       # or sk_test_... for testing
STRIPE_PRICE_ID   = "price_..."         # your $4.99/month recurring price ID
APP_URL           = "https://your-app.streamlit.app"
